{
  "name": "kdm-cli",
  "version": "2.0.1",
  "description": "Kubernetes and Docker Monitoring CLI",
  "type": "module",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KDM-cli/kdm-cli"
  },
  "bugs": {
    "url": "https://github.com/KDM-cli/kdm-cli/issues"
  },
  "homepage": "https://github.com/KDM-cli/kdm-cli#readme",
  "bin": {
    "kdm": "./bin/kdm.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "pretest": "npm run build",
    "test": "vitest run --pool=forks",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "kubernetes",
    "docker",
    "cli",
    "monitor",
    "devops"
  ],
  "author": "",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@vr_patel/tui": "^1.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "commander": "^15.0.0",
    "conf": "^15.1.0",
    "cosmiconfig": "^9.0.0",
    "dockerode": "^5.0.0",
    "ink": "^7.0.5",
    "nodemailer": "^8.0.7",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.26",
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.7",
    "tsup": "^8.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
